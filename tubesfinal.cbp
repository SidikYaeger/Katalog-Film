void updateFilmMenu(adrNode p) {
    int opsi = -1;
    while (opsi != 0) {
        cout << "\n================ UPDATE FILM ================" << endl;
        cout << "Judul Film: " << p->info.judul << endl;
        cout << "1. Tambah Genre Baru" << endl;
        cout << "2. Ubah Tahun Rilis" << endl;
        cout << "3. Ubah Rating" << endl;
        cout << "0. Kembali" << endl;
        cout << "=============================================" << endl;
        cout << "Pilih opsi: ";
        cin >> opsi;
        clearScreen();
        if (opsi == 1) {
            if (p->info.genreCount < genreMax) {
                string newGenre;
                cout << "Masukkan Genre Tambahan: ";
                cin >> newGenre;
                p->info.genre[p->info.genreCount] = newGenre;
                p->info.genreCount++;
                cout << "Genre berhasil ditambahkan." << endl;
            } else {
                cout << "Slot genre sudah penuh." << endl;
            }
        } else if (opsi == 2) {
            cout << "Tahun Lama: ";
            if (p->info.tahun == 0) {
                cout << "-";
                cout << endl;
            }else {
                cout << p->info.tahun << endl;
            }
            cout << "Masukkan Tahun Baru: ";
            cin >> p->info.tahun;
            cout << "Tahun berhasil diubah." << endl;
        } else if (opsi == 3) {
            cout << "Rating Lama: " << p->info.rating << endl;
            cout << "Masukkan Rating Baru: ";
            cin >> p->info.rating;
            cout << "Rating berhasil diubah." << endl;
        } else if (opsi == 0) {
            cout << "Keluar" << endl;
        } else {
            cout << "Pilihan tidak valid." << endl;
        }
    }
}
void EditMenu(tree &t, adrNode p) {
    int opsi = -1;
    bool filmApus = false;

    while (opsi != 0 && !filmApus) {
        clearScreen();
        cout << "\n========================================" << endl;
        cout << "                EDIT FILM                " << endl;
        cout << "========================================" << endl;
        cout << p->info.judul << endl;
        cout << "1. Update" << endl;
        cout << "2. Hapus" << endl;
        cout << "0. Kembali" << endl;
        cout << "----------------------------------------" << endl;
        cout << "Pilih: ";
        cin >> opsi;
        clearScreen();
        if (opsi == 1) {
            updateFilmMenu(p);
            clearScreen();
        } else if (opsi == 2) {
            filmApus = submenuHapus(t, p);
            clearScreen();
        }
    }

}
bool submenuHapus(tree &t, adrNode p) {
    int opsi = -1;
    string judul;
    judul = p->info.judul;

    while (opsi != 0) {
        clearScreen();
        cout << "-------------------------------" << endl;
        cout << "1. Hapus Genre" << endl;
        cout << "2. Hapus Tahun" << endl;
        cout << "3. Hapus Film (by Judul)" << endl;
        cout << "0. Kembali ke Laman Edit" << endl;
        cout << "-------------------------------" << endl;
        cout << "Pilih: ";
        cin >> opsi;

        if (opsi == 1) {
            string g;
            cout << "Masukkan nama genre yang dihapus: ";
            cin >> g;
            hapusGenreFilm(t.root, judul, g);
            cout << "\nTekan Enter untuk melanjutkan"; cin.ignore(); cin.get();

        } else if (opsi == 2) {
            hapusTahunFilm(t.root, judul);
            cout << "\nTekan Enter untuk melanjutkan"; cin.ignore(); cin.get();

        } else if (opsi == 3) {
            char yaqueen;
            cout << "Apakah anda ingin menghapus film " << judul << " (y/n): ";
            cin >> yaqueen;
            if (yaqueen == 'y' || yaqueen == 'Y') {
                t.root = hapusFilm(t.root, judul);
                cout << ">> Film berhasil dihapus." << endl;
                cout << "\nTekan Enter untuk melanjutkan"; cin.ignore(); cin.get();
                return true;
            }
        }
    }
    return false;
}
void opsiLanjutan(tree &t) {
    int subOps;
    cout << "\n=============================================\n";
    cout << "1. Edit Data" << endl;
    cout << "2. Kembali ke Menu Utama" << endl;
    cout << "=============================================" << endl;
    cout << "Pilih opsi: ";
    cin >> subOps;

    if (subOps == 1) {
        string judulTarget;
        cout << "Masukkan Judul Film yang ingin diedit: ";
        cin >> judulTarget;

        adrNode p = cek(t.root, judulTarget);

        if (p != nullptr) {
            EditMenu(t, p);
        } else {
            cout << "\nFilm tidak ditemukan" << endl;
            cout << "Tekan Enter untuk melanjutkan"; cin.ignore(); cin.get();
        }
    } else {
        clearScreen();
    }
}

