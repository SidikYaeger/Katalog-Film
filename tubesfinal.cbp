            cout << root->info.genre[i];
            if(i < root->info.genreCount - 1) {
                cout << ", ";
            }
        }
        cout << endl;
        printPreOrder(root->left);
        printPreOrder(root->right);
    }
}
void printPostOrder(adrNode root){
