void searchTahun(adrNode root, int tahun){
    bool cocok;
    int i;
    if (root != nullptr) {
        searchTahun(root->left, tahun);
        if (root->info.tahun == tahun) {
            cocok = true;
            cout << "===============================\n";
            cout << "Judul  : " << root->info.judul << endl;
            cout << "Tahun  : " << root->info.tahun << endl;
            cout << "Rating : " << root->info.rating << endl;
            cout << "Genre  : ";
            for (i = 0; i < root->info.genreCount; i++) {
                cout << root->info.genre[i];
                if (i < root->info.genreCount - 1) cout << ", ";
            }
            cout << endl;
        }
        searchTahun(root->right, tahun);
    }
}
void searchJudul(adrNode root){
    int i;
    string cari;
    cout << "\n=== Cari Film ===" << endl;
    cout << "Masukkan Judul yang ingin dicari: ";
    cin >> cari;

    adrNode hasil = cek(root, cari);

    if (hasil == nullptr){
        cout << "Film Dengan Judul " << cari << " Tidak Ditemukan\n";
    } else {
        cout << "===============================\n";
        cout << "Judul  : " << hasil->info.judul << endl;
        cout << "Tahun  : " << hasil->info.tahun << endl;
        cout << "Rating : " << hasil->info.rating << endl;
        cout << "Genre  : ";
        for (i = 0; i < hasil->info.genreCount; i++) {
            cout << hasil->info.genre[i];
            if (i < hasil->info.genreCount - 1) cout << ", ";
        }
        cout << "\n===============================\n";
    }
    cout << endl;
    cout << "Tekan Enter untuk melanjutkan"; cin.ignore(); cin.get();
    clearScreen();
}
void searchGenre(adrNode root, string genre){
    bool cocok = false;
    int i,j;
    if (root != nullptr){
        searchGenre(root->left, genre);
        for (i=0; i<root->info.genreCount; i++){
            if (root->info.genre[i] == genre){
                cocok = true;
            }
        }
        if (cocok) {
            cout << "===============================\n";
            cout << "Judul  : " << root->info.judul << endl;
            cout << "Tahun  : " << root->info.tahun << endl;
            cout << "Rating : " << root->info.rating << endl;
            cout << "Genre  : " ;
            for (j = 0; j < root->info.genreCount; j++){
                cout << root->info.genre[j];
                if (j < root->info.genreCount - 1) cout << ", ";
            }
            cout << endl;
        }
        searchGenre(root->right, genre);
    }
}
