#include <iostream>
using namespace std;

void clearScreen(){
    cout << "\033[2J\033[1;1H";
}


void createTree(tree &T) {
    T.root = nullptr;
}
adrNode createNode(film data) {
    adrNode p;
    int i;

    p = new node;
    p->info.judul = data.judul;
    p->info.tahun = data.tahun;
    p->info.rating = data.rating;
    p->info.genreCount = data.genreCount;

    for(i = 0; i < data.genreCount; i++){
        p->info.genre[i] = data.genre[i];
    }
    p->left = nullptr;
    p->right = nullptr;
    return p;
}
adrNode cek(adrNode root, string judul){
    if (root == nullptr){
        return nullptr;
    }
    if (root->info.judul == judul){
        return root;
    }
    if (judul < root->info.judul){
        return cek(root->left, judul);
    } else {
        return cek(root->right, judul);
    }
}
void insertNode(adrNode &root, film data) {
    if (root == nullptr) {
        root = createNode(data);
    } else {
        if (data.judul < root->info.judul) {
            insertNode(root->left, data);
        } else {
            insertNode(root->right, data);
        }
    }
}
