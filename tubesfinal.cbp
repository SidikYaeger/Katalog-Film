void printInOrder(adrNode root) {
    int i;

    if (root != nullptr) {
        printInOrder(root->left);
        cout << "=============================================" << endl;
        cout << "Judul  : " << root->info.judul << endl;
        cout << "Tahun  : " << root->info.tahun << endl;
        cout << "Rating : " << root->info.rating << endl;
        cout << "Genre  : ";
        for (i = 0; i < root->info.genreCount; i++) {
            cout << root->info.genre[i];
            if(i < root->info.genreCount - 1) {
                cout << ", ";
            }
        }
        cout << endl;
        printInOrder(root->right);
    }
}
void printPreOrder(adrNode root) {
