//AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
adrNode findmin(adrNode root){
    if(root == nullptr){
        return nullptr;
    }
    if(root->left == nullptr){
        return root;
    }else{
        return findmin(root->left);
    }
}
int countFilm(adrNode root) {
    if (root == nullptr) {
        return 0;
    }
    return 1 + countFilm(root->left) + countFilm(root->right);
}
int countRating(adrNode root, float rating) {
    if (root == nullptr) {
        return 0;
    }
    int hitung = 0;
    if (root->info.rating == rating) {
        hitung = 1;
    }
    return hitung + countRating(root->left, rating) + countRating(root->right, rating);
}
void printRating(adrNode root, float rating) {
    int i;
    if (root != nullptr) {
        printRating(root->left, rating);
        if (root->info.rating == rating) {
            cout << "=============================================" << endl;
            cout << "Judul  : " << root->info.judul << endl;
            cout << "Tahun  : ";
            if (root->info.tahun == 0) {
                cout << "-";
            } else {
                cout << root->info.tahun;
            }
            cout << endl;
            cout << "Rating : " << root->info.rating << endl;
            cout << "Genre  : ";
            for (i = 0; i < root->info.genreCount; i++) {
                cout << root->info.genre[i];
                if(i < root->info.genreCount - 1) {
                    cout << ", ";
                }
            }
            cout << endl;
        }
        printRating(root->right, rating);
    }
}
void searchByRating(adrNode root, float rating) {
    int jumlah;
    jumlah = countRating(root, rating);
    cout << "\n--- HASIL PENCARIAN RATING " << rating << " ---" << endl;
    if (jumlah == 0) {
        cout << "Tidak ada film dengan rating " << rating << "." << endl;
    } else {
        cout << "Ditemukan " << jumlah << " film dengan rating tersebut:" << endl;
        printRating(root, rating);
    }
    cout << "---------------------------------" << endl;
}
