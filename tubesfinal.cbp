//AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
adrNode hapusFilm(adrNode root, string judul){
    adrNode temp;

    if(root == nullptr){
        return nullptr;
    }
    if(judul < root->info.judul){
        root->left = hapusFilm(root->left, judul);
    }else if(judul > root->info.judul){
        root->right = hapusFilm(root->right, judul);
    }else{
        if(root->left == nullptr && root->right == nullptr){
            delete root;
            root = nullptr;
        }else if(root->left == nullptr){
            temp = root;
            root = root->right;
            delete temp;
        }else if(root->right == nullptr){
            temp = root;
            root = root->left;
            delete temp;
        }else{
            temp = findmin(root->right);
            root->info = temp->info;
            root->right = hapusFilm(root->right, temp->info.judul);
        }
    }
    return root;
}
void hapusTahunFilm(adrNode root, string judul) {
    adrNode p = cek(root, judul);
    if (p != nullptr) {
        p->info.tahun = 0; // NANTI ATUR LAGI AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
        cout << "Tahun rilis film '" << judul << "' berhasil dihapus." << endl;
    } else {
        cout << "Film tidak ditemukan." << endl;
    }
}
void hapusGenreFilm(adrNode root, string judul, string genreHapus) {
    adrNode p = cek(root, judul);
    int i;
    if (p != nullptr) {
        int idx = 0;
        for (i = 0; i < p->info.genreCount; i++) {
            if (p->info.genre[i] == genreHapus && idx == -1) {
                idx = i;
            }
        }
        if (idx != -1) {
            for (i = idx; i < p->info.genreCount - 1; i++) {
                p->info.genre[i] = p->info.genre[i + 1];
            }
            p->info.genreCount--;
            cout << "Genre '" << genreHapus << "' berhasil dihapus dari film " << judul << endl;
        } else {
            cout << "Genre tidak ditemukan pada film tersebut." << endl;
        }
    } else {
        cout << "Film tidak ditemukan." << endl;
    }
}
